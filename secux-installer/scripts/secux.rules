-D
-b 65536
-f 1
--backlog_wait_time 60000
-c

-a always,exit -F dir=/etc/audit/ -F perm=wa -k audit_conf
-a always,exit -F path=/etc/libaudit.conf -F perm=wa -k audit_conf
-a always,exit -F dir=/var/log/audit/ -F perm=wa -k audit_log

-a always,exit -F path=/var/log/wtmp -F perm=wa -k logins
-a always,exit -F path=/var/log/btmp -F perm=wa -k logins
-a always,exit -F path=/var/log/lastlog -F perm=wa -k logins
-a always,exit -F path=/run/utmp -F perm=wa -k logins

-a always,exit -F path=/etc/passwd -F perm=wa -k auth
-a always,exit -F path=/etc/shadow -F perm=wa -k auth
-a always,exit -F path=/etc/group -F perm=wa -k auth
-a always,exit -F path=/etc/gshadow -F perm=wa -k auth
-a always,exit -F path=/etc/login.defs -F perm=wa -k auth
-a always,exit -F dir=/etc/security/ -F perm=wa -k auth
-a always,exit -F dir=/etc/pam.d/ -F perm=wa -k pam

-a always,exit -F path=/etc/sudoers -F perm=wa -k sudo
-a always,exit -F dir=/etc/sudoers.d/ -F perm=wa -k sudo

-a always,exit -F path=/etc/ssh/sshd_config -F perm=wa -k sshd_config
-a always,exit -F dir=/etc/ssh/sshd_config.d/ -F perm=wa -k sshd_config
-a always,exit -F path=/etc/ssh/ssh_config -F perm=wa -k ssh_config
-a always,exit -F dir=/etc/ssh/ssh_config.d/ -F perm=wa -k ssh_config
-a always,exit -F dir=/root/.ssh/ -F perm=wa -k ssh_keys

-a always,exit -F arch=b64 -S init_module,finit_module,delete_module -k kernel_modules
-a always,exit -F path=/usr/bin/kmod -F perm=x -k kernel_modules
-a always,exit -F dir=/etc/modprobe.d/ -F perm=wa -k kernel_modules
-a always,exit -F dir=/etc/modules-load.d/ -F perm=wa -k kernel_modules

-a always,exit -F arch=b64 -S bpf -F auid!=unset -k bpf_load

-a always,exit -F arch=b64 -S adjtimex,settimeofday,clock_settime -F auid!=unset -k time_change
-a always,exit -F path=/etc/localtime -F perm=wa -k time_change

-a always,exit -F arch=b64 -S sethostname,setdomainname -k network_config
-a always,exit -F path=/etc/hostname -F perm=wa -k network_config
-a always,exit -F path=/etc/hosts -F perm=wa -k network_config
-a always,exit -F path=/etc/resolv.conf -F perm=wa -k network_config
-a always,exit -F dir=/etc/systemd/network/ -F perm=wa -k network_config
-a always,exit -F dir=/etc/NetworkManager/ -F perm=wa -k network_config
-a always,exit -F path=/etc/nsswitch.conf -F perm=wa -k nameservice
-a always,exit -F path=/etc/host.conf -F perm=wa -k nameservice

-a always,exit -F path=/etc/nftables.conf -F perm=wa -k firewall
-a always,exit -F dir=/etc/iptables/ -F perm=wa -k firewall
-a always,exit -F path=/usr/bin/nft -F perm=x -k firewall
-a always,exit -F path=/usr/bin/iptables -F perm=x -k firewall

-a always,exit -F dir=/etc/systemd/system/ -F perm=wa -k systemd_persist
-a always,exit -F dir=/usr/lib/systemd/system/ -F perm=wa -k systemd_persist
-a always,exit -F dir=/etc/systemd/user/ -F perm=wa -k systemd_persist
-a always,exit -F dir=/usr/lib/systemd/user/ -F perm=wa -k systemd_persist
-a always,exit -F path=/etc/systemd/logind.conf -F perm=wa -k systemd_persist
-a always,exit -F path=/etc/systemd/journald.conf -F perm=wa -k systemd_persist

-a always,exit -F path=/etc/profile -F perm=wa -k shell_config
-a always,exit -F dir=/etc/profile.d/ -F perm=wa -k shell_config
-a always,exit -F path=/etc/bash.bashrc -F perm=wa -k shell_config
-a always,exit -F path=/etc/environment -F perm=wa -k shell_config
-a always,exit -F path=/etc/shells -F perm=wa -k shell_config
-a always,exit -F path=/etc/ld.so.conf -F perm=wa -k shell_config
-a always,exit -F dir=/etc/ld.so.conf.d/ -F perm=wa -k shell_config
-a always,exit -F path=/etc/ld.so.preload -F perm=wa -k shell_config

-a always,exit -F path=/etc/mkinitcpio.conf -F perm=wa -k initramfs
-a always,exit -F dir=/etc/mkinitcpio.d/ -F perm=wa -k initramfs
-a always,exit -F path=/usr/bin/mkinitcpio -F perm=x -k initramfs
-a always,exit -F dir=/efi/loader/ -F perm=wa -k bootloader
-a always,exit -F path=/usr/bin/bootctl -F perm=x -k bootloader

-a always,exit -F path=/etc/pacman.conf -F perm=wa -k package_manager
-a always,exit -F dir=/etc/pacman.d/ -F perm=wa -k package_manager
-a always,exit -F path=/var/log/pacman.log -F perm=wa -k package_manager
-a always,exit -F path=/usr/bin/pacman -F perm=x -k package_manager

-a always,exit -F arch=b64 -S ptrace -k process_injection
-a always,exit -F arch=b64 -S process_vm_readv,process_vm_writev -k process_injection

-a always,exit -F arch=b64 -S mount,umount2,fsopen,fsmount,move_mount -F auid!=unset -k mounts
-a always,exit -F path=/etc/fstab -F perm=wa -k mounts
-a always,exit -F arch=b64 -S swapon,swapoff -k swap

-a always,exit -F arch=b64 -S openat,openat2,creat,unlink,unlinkat,truncate,ftruncate -F exit=-EPERM -F auid>=1000 -F auid!=unset -k fs_denied
-a always,exit -F arch=b64 -S openat,openat2,creat,unlink,unlinkat,truncate,ftruncate -F exit=-EACCES -F auid>=1000 -F auid!=unset -k fs_denied

-e 2